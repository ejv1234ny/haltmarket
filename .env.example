# haltmarket secrets — copy to .env.local (web) or per-app .env; never commit.

# ─────────────────────────────────────────────────────────────
# Supabase (project ref: gidbmzzbwmodmwlbsngv)
# ─────────────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=gidbmzzbwmodmwlbsngv
SUPABASE_URL=https://gidbmzzbwmodmwlbsngv.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Next.js public-facing (must be prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# ─────────────────────────────────────────────────────────────
# Market data
# ─────────────────────────────────────────────────────────────
POLYGON_API_KEY=

# Nasdaq halt RSS (Phase 2)
NASDAQ_RSS_URL=https://www.nasdaqtrader.com/rss.aspx?feed=tradehalts
HALT_POLL_INTERVAL_SECONDS=3

# ─────────────────────────────────────────────────────────────
# Observability (Phase 1+)
# ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────
# Web Push (Phase 6) — VAPID keys generated by operator, see docs/human-tasks.md #14
# ─────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@haltmarket.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────
# Email (Phase 6 stub, SendGrid)
# ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@haltmarket.com

# ─────────────────────────────────────────────────────────────
# Payments (Phase 8) — StubProvider in dev; real rails are TODO(human)
# ─────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stub
PAYMENT_WEBHOOK_SECRET=
COINBASE_COMMERCE_API_KEY=
CIRCLE_API_KEY=
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET_PATH=

# ─────────────────────────────────────────────────────────────
# Deploy (CI) — referenced by .github/workflows/deploy.yml
# ─────────────────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RAILWAY_TOKEN=

# ─────────────────────────────────────────────────────────────
# Runtime feature flags
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
